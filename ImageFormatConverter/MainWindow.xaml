<Window x:Class="ImageFormatConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ImageConverter" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <ToolBar Grid.Row="0" Height="45">
            <Button Content=" 添加文件 " Click="BtnAddFiles_Click" Margin="5,0" />
            <Button Content=" 清空列表 " Click="BtnClear_Click" Margin="5,0" />
            <Separator />
            <TextBlock Text="输出格式：" VerticalAlignment="Center" Margin="10,0,0,0" />
            <ComboBox x:Name="CmbOutputFormat" Width="100" Margin="5,0" SelectedIndex="0">
                <ComboBoxItem>PNG</ComboBoxItem>
                <ComboBoxItem>JPG</ComboBoxItem>
                <ComboBoxItem>BMP</ComboBoxItem>
                <ComboBoxItem>ICO</ComboBoxItem>
                <ComboBoxItem>SVG</ComboBoxItem>
                <ComboBoxItem>PDF</ComboBoxItem>
                <ComboBoxItem>WEBP</ComboBoxItem>
                <ComboBoxItem>GIF</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="JPG质量：" VerticalAlignment="Center" Margin="15,0,0,0" />
            <Slider x:Name="SldQuality" Width="100" Minimum="10" Maximum="100" Value="90"
                    TickFrequency="10" IsSnapToTickEnabled="True" Height="18" />
            <TextBlock x:Name="TxtQuality" Text="90%" Width="35" VerticalAlignment="Center" />
            <Separator />
            <Button Content=" 开始转换 " Click="BtnConvert_Click" Margin="10,0"
                    Background="#FF4CAF50" Foreground="White" FontWeight="Bold" />
        </ToolBar>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：文件列表 -->
            <Border Grid.Column="0" BorderBrush="#FFCCCCCC" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="待转换文件列表" FontWeight="Bold" Margin="10" Grid.Row="0" />
                    <ListBox x:Name="LstFiles" Grid.Row="1" Margin="10" SelectionChanged="LstFiles_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FileName}" Width="180" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Format}" Foreground="Gray" Margin="5,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 中间：预览区域 -->
            <Grid Grid.Column="1" Background="#FFF5F5F5">
                <Border BorderBrush="#FFDDDDDD" BorderThickness="1" Margin="20" Background="White">
                    <Image x:Name="ImgPreview" Stretch="Uniform" Margin="10" />
                </Border>
                <TextBlock x:Name="TxtPreviewHint" Text="拖拽文件到此处或点击添加文件"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="16" IsHitTestVisible="False" />
            </Grid>

            <!-- 右侧：SVG 颜色设置面板 -->
            <Border Grid.Column="2" BorderBrush="#FFCCCCCC" BorderThickness="1,0,0,0" Background="#FFFAFAFA">
                <StackPanel Margin="15">
                    <TextBlock Text="转换设置" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" />

                    <TextBlock Text="输出目录：" FontWeight="SemiBold" Margin="0,5" />
                    <Grid>
                        <TextBox x:Name="TxtOutputDir" Text="{Binding OutputDirectory}" IsReadOnly="True" Background="#FFEEEEEE" />
                        <Button Content="..." Width="30" HorizontalAlignment="Right" Click="BtnBrowse_Click" />
                    </Grid>

                    <CheckBox x:Name="ChkKeepSize" Content="保持原始尺寸" IsChecked="True" Margin="0,10" />

                    <Separator Margin="0,15" />

                    <!-- SVG 专用颜色面板 -->
                    <TextBlock Text="SVG 颜色替换" FontWeight="Bold" FontSize="13" Margin="0,0,0,10" />
                    <TextBlock Text="（仅对 SVG 文件生效）" Foreground="Gray" FontSize="11" Margin="0,0,0,10" />

                    <TextBlock Text="原颜色（留空则替换全部）：" Margin="0,5" />
                    <TextBox x:Name="TxtOldColor" Text="#000000" Margin="0,0,0,10" />

                    <TextBlock Text="新颜色：" Margin="0,5" />
                    <Grid>
                        <TextBox x:Name="TxtNewColor" Text="#FF5722" Width="150" HorizontalAlignment="Left" />
                        <Border x:Name="BorderColorPreview" Width="30" Height="20" Background="#FF4777"
                                HorizontalAlignment="Right" BorderBrush="Gray" BorderThickness="1" />
                    </Grid>

                    <Button Content=" 选择颜色 " Click="BtnPickColor_Click" Margin="0,10" HorizontalAlignment="Left" />

                    <CheckBox x:Name="ChkReplaceAllColors" Content="替换所有颜色（单色化）" Margin="0,5" />

                    <TextBlock Text="替换模式：" Margin="0,10,0,5" />
                    <ComboBox x:Name="CmbColorMode" SelectedIndex="0">
                        <ComboBoxItem>仅替换 Fill（填充）</ComboBoxItem>
                        <ComboBoxItem>仅替换 Stroke（描边）</ComboBoxItem>
                        <ComboBoxItem>替换 Fill + Stroke</ComboBoxItem>
                        <ComboBoxItem>全局替换（含 Style）</ComboBoxItem>
                    </ComboBox>

                    <Button Content="预览颜色效果" Click="BtnPreviewColor_Click" Margin="0,15"
                            Background="#FF2196F3" Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="2" Height="30">
            <StatusBarItem>
                <ProgressBar x:Name="ProgressBar" Width="200" Height="18" Visibility="Collapsed" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="就绪" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtCount" Text="文件数：0" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>